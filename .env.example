## Copy this file to .env and fill with your deployment values
# Do NOT commit your real .env to version control.

# Full API base URL (preferred). If set, this overrides XANO_INSTANCE.
API_BASE_URL=https://<your-instance>.n7.xano.io/api

# Alternatively, set the Xano instance id (legacy behavior):
XANO_INSTANCE=x8ki-letl-twmt

# HTTP request timeout in seconds (optional)
API_TIMEOUT=15
