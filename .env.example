## Copy this file to .env and fill with your deployment values
# Do NOT commit your real .env to version control.

# For frontend (Next.js) - use this variable
NEXT_PUBLIC_XANO_URL=https://x8ki-letl-twmt.n7.xano.io/api

# Alternative: Set the Xano instance id (will be automatically converted to URL)
# NEXT_PUBLIC_XANO_INSTANCE=x8ki-letl-twmt

# HTTP request timeout in seconds (optional)
API_TIMEOUT=15